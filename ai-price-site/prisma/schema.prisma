  version        String @default("v1")
  selectorConfig Json?  @map("selector_config")
  regexConfig    Json?  @map("regex_config")
  status         String @default("draft")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("parser_rules")
}

model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  actorId String?    @map("actor_id") @db.Uuid
  actor   AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  action     String
  targetType String  @map("target_type")
  targetId   String? @map("target_id") @db.Uuid

  oldValue Json?   @map("old_value")
  newValue Json?   @map("new_value")
  note     String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([targetType, targetId])
  @@map("audit_logs")
}

model EventLog {
  id String @id @default(uuid()) @db.Uuid

  eventKey  String  @map("event_key")
  eventName String? @map("event_name")

  pagePath  String? @map("page_path")
  pageTitle String? @map("page_title")
  referrer  String?

  locale      String? @default("zh")
  sessionId   String? @map("session_id")
  anonymousId String? @map("anonymous_id")

  productId String? @map("product_id") @db.Uuid
  planId    String? @map("plan_id") @db.Uuid
  countryId String? @map("country_id") @db.Uuid
  articleId String? @map("article_id") @db.Uuid

  buttonKey  String? @map("button_key")
  placement  String?
  source     String?
  deviceType String? @map("device_type")

  userAgent String? @map("user_agent")
  ipCountry String? @map("ip_country")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventKey, createdAt])
  @@index([pagePath])
  @@index([productId])
  @@index([planId])
  @@index([countryId])
  @@index([articleId])
  @@index([createdAt])
  @@map("event_logs")
}

model DailyStat {
  id String @id @default(uuid()) @db.Uuid

  statDate DateTime @map("stat_date") @db.Date

  metricKey   String @map("metric_key")
  metricValue Int    @default(0) @map("metric_value")

  dimensionType String @default("global") @map("dimension_type")
  dimensionKey  String @default("global") @map("dimension_key")

  label    String?
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([statDate, metricKey, dimensionType, dimensionKey])
  @@index([statDate])
  @@index([metricKey])
  @@index([dimensionType, dimensionKey])
  @@map("daily_stats")
}
