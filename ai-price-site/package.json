{
    "name":  "ai-price-site",
    "version":  "0.3.0-beta.11",
    "private":  true,
    "scripts":  {
                    "dev":  "next dev",
                    "build":  "next build",
                    "check:local":  "node scripts/check-local-env.cjs",
                    "check:prices":  "node scripts/check-price-quality.cjs",
                    "check:encoding":  "node scripts/check-source-encoding.cjs",
                    "db:up":  "node scripts/local-db.cjs up",
                    "db:status":  "node scripts/local-db.cjs status",
                    "db:doctor":  "node scripts/local-db.cjs doctor",
                    "typecheck":  "tsc --noEmit",
                    "preflight:code":  "npm run check:encoding \u0026\u0026 npm run typecheck \u0026\u0026 npm run lint \u0026\u0026 npm test \u0026\u0026 npm run build",
                    "preflight:full":  "npm run check:local \u0026\u0026 npm run check:prices \u0026\u0026 npm run preflight:code",
                    "seed:local-demo":  "powershell -ExecutionPolicy Bypass -File scripts/seed-local-demo.ps1",
                    "sync:worldbank-income":  "node scripts/sync-world-bank-income.mjs",
                    "start":  "next start",
                    "test":  "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --test app/admin/collector-jobs/job-state.test.mts app/admin/review/collection-status.test.mts app/admin/review/price-review-rules.test.mts app/admin/review/review-reason-copy.test.mts",
                    "lint":  "eslint"
                },
    "dependencies":  {
                         "@prisma/adapter-pg":  "^7.8.0",
                         "@prisma/client":  "^7.8.0",
                         "d3-geo":  "^3.1.1",
                         "dotenv":  "^17.4.2",
                         "html-to-image":  "^1.11.13",
                         "lucide-react":  "^1.21.0",
                         "next":  "16.2.9",
                         "pg":  "^8.22.0",
                         "prisma":  "^7.8.0",
                         "react":  "19.2.4",
                         "react-dom":  "19.2.4",
                         "server-only":  "^0.0.1",
                         "simple-icons":  "^16.24.0",
                         "topojson-client":  "^3.1.0",
                         "world-atlas":  "^2.0.2"
                     },
    "devDependencies":  {
                            "@tailwindcss/postcss":  "^4",
                            "@types/d3-geo":  "^3.1.0",
                            "@types/node":  "^20",
                            "@types/react":  "^19",
                            "@types/react-dom":  "^19",
                            "@types/topojson-client":  "^3.1.5",
                            "eslint":  "^9",
                            "eslint-config-next":  "16.2.9",
                            "tailwindcss":  "^4",
                            "typescript":  "^5"
                        }
}
