# GeoSub Linux ARM64 deployment environment

# Project paths
GEOSUB_BACKEND_DIR=/opt/geosub/geosub-backend
GEOSUB_FRONTEND_DIR=/opt/geosub/ai-price-site
GEOSUB_GIT_BRANCH=main
GEOSUB_SKIP_GIT_PULL=false

# Docker / database
GEOSUB_DB_CONTAINER=geosub-postgres
GEOSUB_DB_NAME=geosub_app
GEOSUB_DB_USER=geosub_admin

# Backups
GEOSUB_BACKUP_DIR=/opt/geosub/backups
GEOSUB_BACKUP_KEEP_DAYS=14

# Collectors
GEOSUB_COUNTRIES=US,CA,JP,PH
GEOSUB_PRODUCT_SLUG=chatgpt
GEOSUB_COLLECTOR_JOB_LIMIT=5

# Exchange rates
GEOSUB_EXCHANGE_RATE_BASE=USD
GEOSUB_EXCHANGE_RATE_QUOTES=CNY
GEOSUB_MAX_EXCHANGE_RATE_AGE_HOURS=18

# Post-deploy health check
GEOSUB_WEB_HEALTH_URL=http://127.0.0.1:3000/zh/ai-pricing

# Discovery scanner
GEOSUB_DISCOVERY_SCAN_LIMIT=20

# Browser rendering
# Leave empty to auto-detect /usr/bin/chromium, /usr/bin/chromium-browser, etc.
CHROME_PATH=

# Runtime tuning for an 8 GB / 6 vCPU ARM server
NODE_OPTIONS=--max-old-space-size=1536

# Upgrade behavior
GEOSUB_RUN_CONTENT_MIGRATIONS=false
